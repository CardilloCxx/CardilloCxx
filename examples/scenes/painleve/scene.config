###############################################
# Painlevé rod scene configuration
###############################################
scene.name=painleve
sim.T=0.5
sim.dt=1e-5
sim.gravity=0 0 -10

# Friction: enable and set a high coefficient for the rod-floor interaction
friction.enable=on
friction.combine=geom
friction.default_mu=1.66666

# Output settings (keep small files for quick interactive testing)
output.interval_steps=5
output.heightfield_stride=8
output.write_contacts=true
output.contacts_body_vectors=false
output.folder=./vtk_out_clarabel
output.filename_prefix=painleve_rod

# Collision settings
collision.broadphase=dynamic_aabb
collision.match_max_dist=0.02
collision.security_margin=0.0

# Projected Jacobi solver settings (defaults tuned for stability)
pj.max_iterations=100000
pj.tol_abs=1e-6
pj.relaxation=1.0
pj.alpha=0.2
pj.compliance=1e-12
pj.nesterov=true
pj.warmstart=true

solver.name = moreau
solver.type = clarabel

# Debug
debug.pj=false
debug.rb=false
