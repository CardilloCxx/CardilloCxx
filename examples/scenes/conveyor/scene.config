scene.name=conveyor

sim.T=5.0
sim.dt=1e-3
sim.gravity=0 0 -9.81

friction.enable=on
friction.combine=geom
friction.default_mu=0.5

output.interval_steps=5
output.heightfield_stride=8
output.write_contacts=true
output.contacts_body_vectors=false
output.folder=./vtk_out
output.filename_prefix=conveyor

collision.disable_all=false
collision.broadphase=dynamic_aabb
collision.match_max_dist=0.02
collision.security_margin=0.0000
collision.max_raw_contacts=150000
collision.max_patches=5000
collision.use_patch_vertices=true
collision.min_pair_contact_distance=0.001

pj.max_iterations=2500
pj.tol_abs=1e-10
pj.tol_rel=1e-10
pj.relaxation=1.0
pj.alpha=0.02
pj.compliance=1e-12
pj.nesterov=true
pj.nesterov_beta_threshold=1.0
pj.nesterov_restart_limit=10000
pj.warmstart=true

solver.name=moreau
moreau.theta=0.5
moreau.implicit_gyroscopy=true
solver.type=pj

constraint_bias_factor=0.000

qoco.backend=cpu
qoco.kkt_static_reg=1e-9
qoco.kkt_dynamic_reg=1e-9
qoco.iter_ref_iters=1

debug.pj=false
debug.rb=false
debug.mesh=false
