###############################################
# Simulation settings
###############################################
sim.T=1.0           # total simulation time (seconds)
# dt=1e-3 (the original value here) is unstable regardless of solver -- PGS and condensed both
# diverge to NaN around simulated t=0.35-0.43s (verified: not a solver bug, both hit it the same
# way). This scene's springs are very stiff (tripod legs k=2e5, ropes/deck k=3e6) for very light
# point masses (0.02-0.05 kg); dt=2e-4 (5x smaller) runs the full sim.T=1.0 without divergence.
sim.dt=2e-4         # time step (seconds)
sim.gravity=0 0 -9.81  # gravity vector gx gy gz (space- or comma-separated). Example: sim.gravity=0,0,-9.81

###############################################
# Friction settings
###############################################
friction.enable=on
friction.combine=geom         # min | arith | geom
friction.default_mu=0.2       # default friction coefficient when not set on entities

###############################################
# Output settings
###############################################
output.interval_steps=1                  # write VTK every N steps
output.heightfield_stride=5              # decimation stride for heightfield VTK (>=1); larger reduces file size
output.write_contacts = true             # write contact VTK files
output.contacts_body_vectors = false     # when true, include body-space normals/tangents/points in contacts VTK
output.folder = ./vtk_out_condensed      # output directory path
output.filename_prefix = hangbridge      #  prefix for output VTK files

###############################################
# Collision settings
###############################################
# collision.broadphase selects the COAL BroadPhase manager used to cull pairs.
# Available values:
#   dynamic_aabb         - DynamicAABBTreeCollisionManager
#   dynamic_aabb_array   - DynamicAABBTreeArrayCollisionManager
#   naive                - NaiveCollisionManager (O(N^2), for debugging)
#   sap                  - SaPCollisionManager (Sort and Prune)
#   ssap                 - SSaPCollisionManager (Multi-axis SaP)
collision.broadphase=dynamic_aabb
collision.match_max_dist=0.02               # maximum distance (in meters) to consider a current contact matched to a previous one (for warmstarting)
collision.security_margin=0.0000            # small positive margin improves robustness for rotating/thin mesh contacts
collision.max_raw_contacts=1000000          # per-pair raw contact cap requested from narrowphase
collision.max_patches=4                 # per-pair patch cap (only relevant when using patch vertices)
collision.use_patch_vertices=true           # when true, emit patch vertices; when false, emit raw contacts
collision.min_pair_contact_distance=0.001   # dedupe contacts within the same entity pair that are closer than this (meters); 0 disables

###############################################
# Projected Jacobi (normal contact) settings
###############################################
pj.max_iterations=500000
pj.tol_abs=1e-5
pj.relaxation=1.0
pj.alpha=0.01
pj.compliance=0.0
pj.nesterov=true                   # enable Nesterov acceleration for Projected Jacobi
pj.nesterov_beta_threshold=1.0     # reset momentum when beta exceeds this (0..1), higher = more aggressive
pj.nesterov_restart_limit=10000    # after this many resets in a solve, disable momentum for the remainder
pj.warmstart=true                  # enable warmstarting & caching of contact impulses across steps

###############################################
# Solver settings
# solver.type options: projected_jacobi | pj | projected_gauss_seidel | pgs | condensed |
#                       qoco | clarabel | conicxx | conjugate_gradient | cg
###############################################
solver.name=moreau
moreau.theta=0.5
moreau.implicit_gyroscopy=false
moreau.lambda_theta=false
solver.type=condensed
constraint_bias_factor=0.1

###############################################
# Condensed solver settings
###############################################
condensed.sweep_mode=colored          # jacobi | gauss_seidel | colored | chaotic
# hangbridge is the one example scene with a branching (non-chain) compliant network -- tripod
# apexes and deck planks have spring degree 4-6, not the degree-<=2 simple chains every other
# scene uses. Useful as the one real test case for anything that assumes a general (not just
# path-graph) bilateral topology.
condensed.local_solve=projection      # projection | newton
condensed.ordering=natural            # natural | dominant (not yet used by any sweep mode)
condensed.num_threads=8               # 0 = OpenMP default (all available cores)
condensed.newton_max_iters=8
condensed.newton_tol=1e-10
condensed.chaotic_reshuffle_interval=50
condensed.chaotic_seed=12345

###############################################
# Debug settings
###############################################
debug.pj=false
debug.rb=false
debug.mesh=false
