scene.name = chain

###############################################
# R scene configuration
###############################################
sim.T=2
sim.dt=5e-4
sim.gravity=0 0 -9.81

# Friction: enable and set a high coefficient for the rod-floor interaction
friction.enable=on
friction.combine=geom
friction.default_mu=0.2

# Output settings (keep small files for quick interactive testing)
output.interval_steps=100
output.heightfield_stride=8
output.write_contacts=true
output.contacts_body_vectors=false
output.folder=./vtk_out
output.filename_prefix=chain

# Collision settings
collision.broadphase=dynamic_aabb
collision.match_max_dist=0.02
collision.security_margin=0.0
collision.security_margin=0.0000            # small positive margin improves robustness for rotating/thin mesh contacts
collision.max_raw_contacts=1000000          # per-pair raw contact cap requested from narrowphase
collision.max_patches=16                 # per-pair patch cap (only relevant when using patch vertices)
collision.min_pair_contact_distance=0.001   # dedupe contacts within the same entity pair that are closer than this (meters); 0 disables

# Projected Jacobi solver settings (defaults tuned for stability)
pj.max_iterations=500000
pj.tol_abs=5e-7
pj.relaxation=1.0
pj.alpha=0.075
pj.compliance=1e-12
pj.nesterov=true
pj.warmstart=true

# Debug
debug.pj=false
debug.rb=false

pj.convergence_csv_dir=chain_nesterov_warmstart_csv
