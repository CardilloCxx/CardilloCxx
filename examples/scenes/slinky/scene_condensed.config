scene.name = slinky

###############################################
# Simulation settings
###############################################
sim.T=0.5
sim.dt=5e-4
sim.gravity=0 0 -9.81

###############################################
# Friction settings
###############################################
friction.enable=on
friction.combine=geom
friction.default_mu=0.2

###############################################
# Output settings
###############################################
output.interval_steps=1
output.write_contacts = true
output.contacts_body_vectors = true
output.folder = ./vtk_out_condensed
output.filename_prefix = slinky

###############################################
# Collision settings
###############################################
collision.broadphase=dynamic_aabb
collision.match_max_dist=0.02
collision.security_margin=0.0000
collision.max_raw_contacts=1000000
collision.max_patches=4
collision.use_patch_vertices=true
collision.min_pair_contact_distance=0.001

###############################################
# Shared iterative-solver knobs (reused verbatim from PJ/PGS -- see docs/chapters/solvers/)
###############################################
pj.max_iterations=500000
pj.tol_abs=1e-5
pj.tol_rel=1e-5
pj.relaxation=1.0
pj.alpha=0.3
pj.warmstart=true
# Nesterov (FISTA-style) acceleration, ported from PJ, reused verbatim by condensed's generic
# doSweep wrapper (see docs/chapters/solvers/condensed.rst). Measured on this scene:
# gauss_seidel+Nesterov is ~1.4x faster wall-clock than PJ's own default accelerated configuration
# (8.39s vs 12.04s) and beats layering Newton on top (10.97s) -- keep local_solve=projection below.
# NOTE: jacobi+Nesterov diverges (NaN) on this scene's strongly-coupled spring chain -- do not
# switch sweep_mode to jacobi without also disabling pj.nesterov.
pj.nesterov=true
pj.nesterov_beta_threshold=1.0
pj.nesterov_restart_limit=100000

###############################################
# Solver settings
# solver.type options: projected_jacobi | pj | projected_gauss_seidel | pgs | condensed |
#                       qoco | clarabel | conicxx | conjugate_gradient | cg
###############################################
solver.name=moreau
moreau.theta=0.6
moreau.implicit_gyroscopy=false
solver.type=condensed
constraint_bias_factor=0.1

###############################################
# Condensed solver settings
###############################################
# slinky is the frictional + compliant (elastic chain) scene -- the case where the semismooth
# Newton local solve's per-contact accuracy is expected to matter most (see docs/chapters/
# solvers/condensed.rst); colored coloring degenerates toward one contact per color on a long
# serial chain like this, so gauss_seidel is the more representative default here.
condensed.sweep_mode=colored     # jacobi | gauss_seidel | colored | chaotic
condensed.local_solve=projection      # projection | newton
condensed.ordering=natural            # natural | dominant (not yet used by any sweep mode)
condensed.num_threads=8               # 0 = OpenMP default (all available cores)
condensed.newton_max_iters=8
condensed.newton_tol=1e-8
condensed.chaotic_reshuffle_interval=50
condensed.chaotic_seed=12345
# true_schur exactly eliminates the spring/damper chain instead of sweeping it -- a huge win
# (~25x wall-clock in one test) at low alpha/no acceleration, but measured SLOWER at this file's
# tuned alpha=1.0+colored+Nesterov settings (the two techniques attack the same bottleneck and
# don't stack). See docs/chapters/solvers/condensed.rst; left off here since this config is
# already tuned via the other route.
condensed.true_schur=true

###############################################
# Debug settings
###############################################
debug.pj=false
debug.rb=false
debug.mesh=false
