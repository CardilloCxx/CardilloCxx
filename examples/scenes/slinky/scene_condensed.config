scene.name = slinky

###############################################
# Simulation settings
###############################################
sim.T=2.0
sim.dt=1e-4
sim.gravity=0 0 -9.81

###############################################
# Friction settings
###############################################
friction.enable=on
friction.combine=geom
friction.default_mu=0.3

###############################################
# Output settings
###############################################
output.interval_steps=20
output.write_contacts = true
output.contacts_body_vectors = true
output.folder = ./vtk_out_condensed
output.filename_prefix = slinky

###############################################
# Collision settings
###############################################
collision.broadphase=dynamic_aabb
collision.match_max_dist=0.02
collision.security_margin=0.0000
collision.max_raw_contacts=1000000
collision.max_patches=10000
collision.use_patch_vertices=true
collision.min_pair_contact_distance=0.001

###############################################
# Shared iterative-solver knobs (reused verbatim from PJ/PGS -- see docs/chapters/solvers/)
###############################################
pj.max_iterations=500000
pj.tol_abs=5e-4
pj.relaxation=0.9
pj.alpha=0.3
pj.warmstart=true
# Nesterov (FISTA-style) acceleration, ported from PJ, reused verbatim by condensed's generic
# doSweep wrapper (see docs/chapters/solvers/condensed.rst). gauss_seidel+Nesterov measured ~1.4x
# faster wall-clock than PJ's own default accelerated configuration (8.39s vs 12.04s).
# NOTE: alpha=0.3 here is tuned for gauss_seidel/colored. `jacobi` (with or without Nesterov)
# diverges to NaN at this alpha -- this is the SAME per-sweep-mode instability documented in
# domino's scene_condensed.config (Jacobi has a smaller stability margin than Gauss-Seidel at a
# given alpha), not a Nesterov-specific effect: a plain, unaccelerated jacobi sweep at alpha=0.3
# diverges here too. If switching sweep_mode to jacobi, also drop pj.alpha to ~0.02 (confirmed
# stable over 1000+ steps at ~11 it/s); do not just disable Nesterov and keep alpha=0.3.
pj.nesterov=true
pj.nesterov_beta_threshold=0.995
pj.nesterov_restart_limit=4

###############################################
# Solver settings
# solver.type options: projected_jacobi | pj | projected_gauss_seidel | pgs | condensed |
#                       qoco | clarabel | conicxx | conjugate_gradient | cg
###############################################
solver.name=moreau
moreau.theta=0.5
moreau.implicit_gyroscopy=false
solver.type=condensed

###############################################
# Condensed solver settings
###############################################
# slinky is the frictional + compliant (elastic chain) scene.
condensed.sweep_mode=colored     # jacobi | gauss_seidel | colored | chaotic
condensed.local_solve=projection          # projection | newton
condensed.ordering=natural            # natural | dominant (not yet used by any sweep mode)
condensed.num_threads=0               # 0 = OpenMP default (all available cores)
condensed.newton_max_iters=8
condensed.newton_tol=1e-10
condensed.chaotic_reshuffle_interval=50
condensed.chaotic_seed=12345

###############################################
# Debug settings
###############################################
debug.pj=false
debug.rb=false
debug.mesh=false
