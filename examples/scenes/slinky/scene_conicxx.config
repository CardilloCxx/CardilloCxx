scene.name = slinky

###############################################
# Simulation settings
###############################################
sim.T=1.0
sim.dt=5e-4
sim.gravity=0 0 -9.81

###############################################
# Friction settings
###############################################
friction.enable=on
friction.combine=geom
friction.default_mu=0.2

###############################################
# Output settings
###############################################
output.interval_steps=1
output.heightfield_stride=5
output.write_contacts = true
output.contacts_body_vectors = true
output.folder = ./vtk_out_conicxx
output.filename_prefix = slinky

###############################################
# Collision settings
###############################################
collision.broadphase=dynamic_aabb
collision.match_max_dist=0.02
collision.security_margin=0.0000
collision.max_raw_contacts=1000000
collision.max_patches=10000
collision.use_patch_vertices=true
collision.min_pair_contact_distance=0.001

###############################################
# Projected Jacobi (normal contact) settings
###############################################
pj.max_iterations=500
pj.tol_abs=1e-4
pj.tol_rel=1e-4
pj.relaxation=1.0
pj.alpha=0.1
pj.compliance=1e-12
pj.nesterov=true
pj.nesterov_beta_threshold=1.0
pj.nesterov_restart_limit=10000
pj.warmstart=true

###############################################
# Solver settings
###############################################
solver.name=moreau
solver.type=conicxx

moreau.theta=0.6
moreau.implicit_gyroscopy=false

# ConicXX-specific: it can reuse its KKT factorization and warm-start its own
# iterate across steps when the active contact set is unchanged, unlike
# QOCO/Clarabel which rebuild from scratch every step (see
# docs/chapters/solvers/interior_point.rst).
conicxx.warm_start = true
#conicxx.warm_start = false

solver.kkt_static_reg = 1e-10
solver.kkt_dynamic_reg = 1e-10
# solver.kkt_static_reg = 1e-8
# solver.kkt_dynamic_reg = 1e-8
solver.iter_ref_iters = 2

#constraint_bias_factor=0.25
constraint_bias_factor=0.1

###############################################
# Debug settings
###############################################
debug.pj=true
debug.rb=false
debug.mesh=false
