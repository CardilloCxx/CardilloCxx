scene.name = net

###############################################
# Simulation settings
###############################################
sim.T=1.0          # total simulation time (seconds)
sim.dt=1e-4        # time step (seconds)
sim.gravity=0 0 -9.81  # gravity vector gx gy gz (space- or comma-separated). Example: sim.gravity=0,0,-9.81

###############################################
# Friction settings
###############################################
friction.enable=on
friction.combine=geom         # min | arith | geom
friction.default_mu=0.1       # default friction coefficient when not set on entities

###############################################
# Output settings
###############################################
output.interval_steps=10                 # write VTK every N steps
output.heightfield_stride=5              # decimation stride for heightfield VTK (>=1); larger reduces file size
output.write_contacts = true             # write contact VTK files
output.contacts_body_vectors = true      # when true, include body-space normals/tangents/points in contacts VTK
output.folder = ./vtk_out                # output directory path
output.filename_prefix = net     #  prefix for output VTK files


###############################################
# Collision settings
###############################################
# collision.broadphase selects the COAL BroadPhase manager used to cull pairs.
# Available values:
#   dynamic_aabb         - DynamicAABBTreeCollisionManager
#   dynamic_aabb_array   - DynamicAABBTreeArrayCollisionManager
#   naive                - NaiveCollisionManager (O(N^2), for debugging)
#   sap                  - SaPCollisionManager (Sort and Prune)
#   ssap                 - SSaPCollisionManager (Multi-axis SaP)
collision.broadphase=dynamic_aabb
collision.match_max_dist=0.02               # maximum distance (in meters) to consider a current contact matched to a previous one (for warmstarting)
collision.security_margin=0.0000            # small positive margin improves robustness for rotating/thin mesh contacts
collision.max_raw_contacts=1000000          # per-pair raw contact cap requested from narrowphase
collision.max_patches=10000                 # per-pair patch cap (only relevant when using patch vertices)
collision.use_patch_vertices=true           # when true, emit patch vertices; when false, emit raw contacts
collision.min_pair_contact_distance=0.001   # dedupe contacts within the same entity pair that are closer than this (meters); 0 disables

###############################################
# Projected Jacobi (normal contact) settings
###############################################
pj.max_iterations=500000
pj.tol_abs=5e-4
pj.relaxation=1.0
pj.alpha=0.01
pj.compliance=1e-12
pj.nesterov=true                   # enable Nesterov acceleration for Projected Jacobi
pj.nesterov_beta_threshold=1.0     # reset momentum when beta exceeds this (0..1), higher = more aggressive
pj.nesterov_restart_limit=10000    # after this many resets in a solve, disable momentum for the remainder
pj.warmstart=true                  # enable warmstarting & caching of contact impulses across steps

###############################################
# Solver settings
###############################################
solver.name=moreau                     # solver type: moreau | stoermverlet
moreau.theta=0.55
moreau.implicit_gyroscopy=true
moreau.lambda_theta=true

###############################################
# Debug settings
###############################################
debug.pj=false
debug.rb=false
debug.mesh=false

