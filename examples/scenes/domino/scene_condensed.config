scene.name=domino

###############################################
# Simulation settings
###############################################
sim.T=10.0          # total simulation time (seconds)
sim.dt=2e-4         # time step (seconds)
sim.gravity=0 0 -9.81  # gravity vector gx gy gz (space- or comma-separated). Example: sim.gravity=0,0,-9.81

###############################################
# Friction settings
###############################################
friction.enable=on
friction.combine=geom         # min | arith | geom
friction.default_mu=0.2       # default friction coefficient when not set on entities

###############################################
# Output settings
###############################################
output.interval_steps=5                 # write VTK every N steps
output.heightfield_stride=5              # decimation stride for heightfield VTK (>=1); larger reduces file size
output.write_contacts = true             # write contact VTK files
output.contacts_body_vectors = true      # when true, include body-space normals/tangents/points in contacts VTK
output.folder = ./vtk_out_condensed       # output directory path
output.filename_prefix = domino_small           #  prefix for output VTK files

###############################################
# Collision settings
###############################################
collision.broadphase=dynamic_aabb
collision.match_max_dist=0.02               # maximum distance (in meters) to consider a current contact matched to a previous one (for warmstarting)
collision.security_margin=0.0000            # small positive margin improves robustness for rotating/thin mesh contacts
collision.max_raw_contacts=1000000          # per-pair raw contact cap requested from narrowphase
collision.max_patches=10000                 # per-pair patch cap (only relevant when using patch vertices)
collision.use_patch_vertices=true           # when true, emit patch vertices; when false, emit raw contacts
collision.min_pair_contact_distance=0.001   # dedupe contacts within the same entity pair that are closer than this (meters); 0 disables

###############################################
# Shared iterative-solver knobs (reused verbatim from PJ/PGS -- see docs/chapters/solvers/)
###############################################
pj.max_iterations=500000
pj.tol_abs=5e-8
pj.tol_rel=1e-4
pj.relaxation=1.0
# alpha=0.3 (the header default) diverges in `jacobi` sweep mode on this scene -- Jacobi is less
# stable than Gauss-Seidel at the same contact step size, and this scene's ~13k densely-packed
# frictional contacts are already tuned to alpha=0.001 in scene_standard.config; reuse that
# proven-stable value rather than the generic default.
pj.alpha=0.001
pj.warmstart=true

###############################################
# Solver settings
# solver.type options: projected_jacobi | pj | projected_gauss_seidel | pgs | condensed |
#                       qoco | clarabel | conicxx | conjugate_gradient | cg
###############################################
solver.name=moreau
moreau.theta=0.5
moreau.implicit_gyroscopy=false
moreau.lambda_theta=false
solver.type=condensed

###############################################
# Condensed solver settings
###############################################
condensed.sweep_mode=jacobi           # jacobi | gauss_seidel | colored | chaotic
# NOTE: measured on this scene, `colored` currently loses to `jacobi`/`gauss_seidel` despite being
# parallel -- ~50 colors x thousands of sweeps means ~50x the OpenMP barrier count of jacobi's 2
# barriers/sweep, and that overhead dominates here. Kept available for the ablation sweep in
# tools/compare_solver_traces.py; not the default until the coloring is cached across steps and/or
# amortized over more work per barrier.
condensed.local_solve=projection      # projection | newton
condensed.ordering=natural            # natural | dominant (not yet used by any sweep mode)
condensed.num_threads=0               # 0 = OpenMP default (all available cores)
condensed.newton_max_iters=8
condensed.newton_tol=1e-10
condensed.chaotic_reshuffle_interval=50
condensed.chaotic_seed=12345

###############################################
# Debug settings
###############################################
debug.pj=false
debug.rb=false
debug.mesh=false
