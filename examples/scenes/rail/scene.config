###############################################
# Rail scene configuration
###############################################
sim.T=6.0
sim.dt=1e-3
sim.gravity=0 0 -9.81

# Friction
friction.enable=on
friction.combine=geom
friction.default_mu=0.4

# Output
output.interval_steps=10
output.heightfield_stride=8
output.write_contacts=true
output.folder=./vtk_out
output.filename_prefix=rail

# Collision settings
collision.broadphase=dynamic_aabb
collision.match_max_dist=0.02
collision.security_margin=0.0
collision.max_raw_contacts=100000
collision.max_patches=10000
collision.min_pair_contact_distance=0.001

# Projected Jacobi solver settings (defaults tuned for stability)
pj.max_iterations=50000
pj.tol_abs=5e-5
pj.relaxation=1.0
pj.alpha=0.1
pj.compliance=1e-12
pj.nesterov=true
pj.warmstart=true

# Debug
debug.pj=true
debug.rb=true
