scene.name = dynamic_constraint

###############################################
# Simulation settings
###############################################
sim.T=0.1
sim.dt=1e-3
sim.gravity=0 0 -9.81

###############################################
# Friction settings
###############################################
friction.enable=off

###############################################
# Output settings
###############################################
output.interval_steps=1
output.write_contacts=false
output.folder = ./vtk_out_dynamic_constraint
output.filename_prefix = dynamic_constraint

###############################################
# Collision settings (no contacts in this scene -- pure bilateral/spring test)
###############################################
collision.disable_all=true

###############################################
# Shared iterative-solver knobs
###############################################
pj.max_iterations=200000
pj.tol_abs=1e-10
pj.tol_rel=1e-10
pj.relaxation=1.0
pj.alpha=0.3
pj.warmstart=true
pj.nesterov=false

###############################################
# Solver settings
# solver.type options: projected_jacobi | pj | projected_gauss_seidel | pgs | condensed |
#                       qoco | clarabel | conicxx | conjugate_gradient | cg
###############################################
solver.name=moreau
moreau.theta=0.5
moreau.implicit_gyroscopy=false
solver.type=condensed

###############################################
# Condensed solver settings
###############################################
condensed.sweep_mode=gauss_seidel
condensed.local_solve=projection
condensed.num_threads=0
condensed.true_schur=true

###############################################
# Debug settings
###############################################
debug.pj=false
debug.rb=false
debug.mesh=false
